#!/usr/bin/env bash


# Check if we are in WSL and clip.exe is available
if grep -q "microsoft" /proc/version && command -v clip.exe >/dev/null 2>&1; then
    cat "$@" | clip.exe
    exit 0
fi

seq="$(cat "$@" | base64 | tr -d "\r\n")"
seq="\ePtmux;\e\e]52;c;$seq\a\e\\"

if [[ -n "${TMUX}" ]]; then
  echo -n "$input" | tmux load-buffer -
  # WSL
  if grep -q "microsoft" /proc/version 2>/dev/null && command -v clip.exe >/dev/null 2>&1; then
    echo -n "$input" | clip.exe
  else
    ssh_tty=$(tmux showenv SSH_TTY 2>/dev/null | grep -v '^-' | cut -d= -f2)
    if [[ -n "$ssh_tty" ]]; then
      printf "$seq" > "$ssh_tty"
    else
      pane_active_tty=$(tmux list-panes -F "#{pane_active} #{pane_tty}" | awk '$1=="1" { print $2 }')
      printf "$seq" > "$pane_active_tty"
    fi
  fi
elif grep -q "microsoft" /proc/version 2>/dev/null && command -v clip.exe >/dev/null 2>&1; then
  echo -n "$input" | clip.exe
elif [[ -n "${SSH_TTY}" ]]; then
  printf "$seq" > "$SSH_TTY"
# macOS
elif command -v pbcopy >/dev/null 2>&1; then
  echo -n "$input" | pbcopy
# Linux xclip
elif command -v xclip >/dev/null 2>&1; then
  echo -n "$input" | xclip -selection clipboard
# Linux xsel
elif command -v xsel >/dev/null 2>&1; then
  echo -n "$input" | xsel --clipboard --input
# Wayland wl-copy
elif command -v wl-copy >/dev/null 2>&1; then
  echo -n "$input" | wl-copy
else
  target_tty="${SSH_TTY:-$(tty)}"
  printf "$seq" > "$target_tty"
fi
