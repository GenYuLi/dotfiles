% tools, display

# 關閉螢幕（DPMS off，動滑鼠或按鍵喚醒）
~/tools/display-off.sh

% tools, kde, google

# 修復 KDE Google 帳號整合（加入 Drive scope）
~/tools/fix_kde_google_intergration.sh

% tools, tmux, env

# 更新現有 shell 的 tmux 環境變數（DISPLAY, WAYLAND_DISPLAY 等）
eval "$(tmux show-environment -s 2>/dev/null)"

% tools, mako, notification

# 清除所有通知
makoctl dismiss --all

# 重新載入 mako 設定
makoctl reload
